# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=hr_documents

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# Models
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=128

# Search
TOP_K_RETRIEVE=30
TOP_K_RERANK=5
RRF_K=60

# API
API_HOST=0.0.0.0
API_PORT=8000

# LLM generation
LLM_TEMPERATURE=0.2
LLM_TOP_P=0.9
LLM_MAX_TOKENS=1024
