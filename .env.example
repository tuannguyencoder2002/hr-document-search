# Qdrant
QDRANT_MODE=local
QDRANT_LOCAL_PATH=
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=hr_documents

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_KEEP_ALIVE=30m
OLLAMA_NUM_GPU=-1

# Models
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=128

# Search
TOP_K_RETRIEVE=30
TOP_K_RERANK=5
RRF_K=60

# API
API_HOST=0.0.0.0
API_PORT=8000

# LLM generation
LLM_TEMPERATURE=0.2
LLM_TOP_P=0.9
LLM_MAX_TOKENS=512

# Image search (CLIP)
IMAGE_SEARCH_ENABLED=true
CLIP_TEXT_MODEL=sentence-transformers/clip-ViT-B-32-multilingual-v1
CLIP_IMAGE_MODEL=sentence-transformers/clip-ViT-B-32
CLIP_VECTOR_SIZE=512
IMAGE_COLLECTION=hr_images
IMAGE_MIN_WIDTH=80
IMAGE_MIN_HEIGHT=80
IMAGE_TOP_K=3
